rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Authenticated users can read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Agents collection: only authenticated server-side (Admin SDK bypasses rules)
    // This rule blocks any unauthenticated client-side access
    match /agents/{agentId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Public read-only data (if needed in the future)
    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
